{
  "name": "apple-stocks-watchlist-mcp",
  "version": "1.1.0",
  "description": "macOS-only MCP server that reads your pre-installed Apple Stocks app — its watchlist and cached quotes — with first-class support for Apple (AAPL). No external API.",
  "type": "module",
  "bin": {
    "apple-stocks-watchlist-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build:test && node --test \"dist-test/test/**/*.test.js\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "stocks",
    "apple-stocks",
    "watchlist",
    "finance",
    "aapl"
  ],
  "author": "Helder Pimenta",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "bplist-parser": "^0.3.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
